  QUIZ2: [
    { q: "ПЛЕЙСХО?", options: ["ПЛЕЙСХОЛДЕР A", "ПЛЕЙСХОЛДЕР B", "ПЛЕЙСХОЛДЕР C", "ПЛЕЙСХОЛДЕР D"], correct: 0 },
    { q: "ПЛЕЙСХОР?", options: ["ПЛЕЙСХОЛДЕР A", "ПЛЕЙСХОЛДЕР B", "ПЛЕЙСХОЛДЕР C", "ПЛЕЙСХОЛДЕР D"], correct: 0 },
    { q: "ПЛЕЙСХДЕР", options: ["ПЛЕЙСХОЛДЕР A", "ПЛЕЙСХОЛДЕР B", "ПЛЕЙСХОЛДЕР C", "ПЛЕЙСХОЛДЕР D"], correct: 0 }
  ]
};

// photo: путь к файлу — если указан, вместо иконки показывается фотокарточка
const ACHIEVEMENTS = {
  code1: { title: "Квест начался", desc: "Ты нашла первый секретный код и открыла дверь в историю", icon: "💌", photo: "photo1.jpg" },
  quiz1: { title: "Испытание пройдено", desc: "Первый тест позади — вселенная впечатлена", icon: "🧠", photo: "photo2.png" },
  code2: { title: "Второй код найден", desc: "Путь ко второму подарку открыт", icon: "🔑", photo: "photo3.jpg" },
  quiz2: { title: "Финальное испытание", desc: "Ты прошла квест до самого конца", icon: "👑", photo: "" }
};
const ACHV_ORDER = ["code1","quiz1","code2","quiz2"];

(function initStars(){
  const wrap = document.getElementById('stars');
  const count = window.innerWidth < 500 ? 40 : 70;
  for(let i=0;i<count;i++){
    const s = document.createElement('span');
    s.style.left = Math.random()*100 + '%';
    s.style.top = Math.random()*100 + '%';
    s.style.animationDelay = (Math.random()*4) + 's';
    wrap.appendChild(s);
  }
})();

const STORAGE_KEY = 'rtm_gift_state_v1';
function loadState(){
  try{
    const raw = localStorage.getItem(STORAGE_KEY);
    if(!raw) return defaultState();
    return Object.assign(defaultState(), JSON.parse(raw));
  }catch(e){ return defaultState(); }
}
function defaultState(){
  return {
    code1Verified:false, quiz1Passed:false, quiz1LastScore:null,
    code2Verified:false, unlockTimestamp:null, adminOverride:false,
    quiz2Passed:false, quiz2LastScore:null,
    usedCode1:null,
    fishingPassed:false,
    gift1Seen:false,
    achievements:{ code1:false, quiz1:false, code2:false, quiz2:false }
  };
}
function saveState(state){ localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }
let state = loadState();

(function checkResetParam(){
  const params = new URLSearchParams(window.location.search);
  if(params.get('reset') === '1'){
    localStorage.removeItem(STORAGE_KEY);
    state = defaultState();
    window.history.replaceState({}, '', window.location.pathname);
  }
})();

const SCREENS = ['screen-code1','screen-quiz1','screen-quiz1-fail','screen-quiz1-success',
                  'screen-lock','screen-code2-entry','screen-quiz2','screen-quiz2-fail','screen-final'];
function showScreen(id){
  SCREENS.forEach(s=>{ document.getElementById(s).classList.remove('active'); });
  document.getElementById(id).classList.add('active');
}
function stageIndex(){
  if(!state.code1Verified) return 0;
  if(!state.quiz1Passed) return 1;
  if(!state.gift1Seen) return 2;
  if(!isUnlocked()) return 3;
  if(!state.code2Verified) return 4;
  if(!state.quiz2Passed) return 5;
  return 6;

}
function renderConstellation(){
  const total = 5;
  const done = stageIndex();
  const el = document.getElementById('constellation');
  el.innerHTML = '';
  for(let i=0;i<total;i++){
    const node = document.createElement('div');
    node.className = 'node' + (i < done ? ' done' : (i===done ? ' done' : ''));
    el.appendChild(node);
    if(i < total-1){
      const link = document.createElement('div');
      link.className = 'link' + (i < done ? ' done' : '');
      el.appendChild(link);
    }
  }
}
function isUnlocked(){
  if(state.adminOverride) return true;
  if(!state.unlockTimestamp) return false;
  return Date.now() >= state.unlockTimestamp;
}
function render(){
  renderConstellation(); // (или renderAchievementShelf — как у тебя называется, не трогай эту строку)
  if(state.quiz1Passed && !state.fishingPassed){
    window.location.href = 'game.html';
    return;
  }
const idx = stageIndex();
  if(idx === 0){
    showScreen('screen-code1');
  } else if(idx === 1){
    buildQuiz('quiz1', CONFIG.QUIZ1, 'quiz1-questions');
    showScreen('screen-quiz1');
  } else if(idx === 2){
    document.getElementById('quiz1-score-success').textContent =
      'Результат: ' + Math.round(state.quiz1LastScore*100) + '%';
    showScreen('screen-quiz1-success');
  } else if(idx === 3){
    if(!state.unlockTimestamp){
      state.unlockTimestamp = Date.now() + CONFIG.LOCK_DAYS*24*60*60*1000;
      saveState(state);
    }
    showScreen('screen-lock');
    startTimerLoop();
  } else if(idx === 4){
    showScreen('screen-code2-entry');
  } else if(idx === 5){
    buildQuiz('quiz2', CONFIG.QUIZ2, 'quiz2-questions');
    showScreen('screen-quiz2');
  } else if(idx === 6){
    document.getElementById('quiz2-score-final').textContent =
      'Результат: ' + Math.round(state.quiz2LastScore*100) + '%';
    showScreen('screen-final');
  }
}

function normalize(v){ return (v||'').trim().toLowerCase(); }

function submitCode1(){
  const input = document.getElementById('input-code1');
  const errorEl = document.getElementById('error-code1');
  const validCodes = CONFIG.CODE1.map(normalize);
  const typed = normalize(input.value);
  if(validCodes.includes(typed)){
    state.code1Verified = true;
    state.usedCode1 = typed;
    saveState(state);
    errorEl.textContent = '';
    unlockAndShow('code1', render);
  } else {
    errorEl.textContent = 'Неверный код. Попробуй ещё раз.';
    input.classList.remove('shake');
    void input.offsetWidth;
    input.classList.add('shake');
  }
}

function submitCode2(){
  const input = document.getElementById('input-code2');
  const errorEl = document.getElementById('error-code2');
  const typed = normalize(input.value);
  const validCodes = CONFIG.CODE1.map(normalize).filter(c => c !== state.usedCode1);
  if(validCodes.includes(typed)){
    state.code2Verified = true;
    saveState(state);
    errorEl.textContent = '';
    unlockAndShow('code2', render);
  } else {
    errorEl.textContent = 'Неверный код. Попробуй ещё раз.';
    input.classList.remove('shake');
    void input.offsetWidth;
    input.classList.add('shake');
  }
}

let quizProgress = { quiz1: 0, quiz2: 0 };
let quizAnswers  = { quiz1: {}, quiz2: {} };
function continueToLock(){
  state.gift1Seen = true;
  saveState(state);
  render();
}
function buildQuiz(key, questions, containerId){
  const container = document.getElementById(containerId);
  container.innerHTML = '';
  const qi = quizProgress[key];
  const item = questions[qi];
  const qDiv = document.createElement('div');
  qDiv.className = 'question';
  const qText = document.createElement('div');
  qText.className = 'q-text';
  qText.textContent = 'Вопрос ' + (qi+1) + ' из ' + questions.length + '. ' + item.q;
  qDiv.appendChild(qText);
  item.options.forEach((opt, oi)=>{
    const label = document.createElement('label');
    label.className = 'option';
    if(quizAnswers[key][qi] === oi) label.classList.add('selected');
    label.innerHTML =
      '<input type="radio" name="'+key+'-q'+qi+'" value="'+oi+'"' +
      (quizAnswers[key][qi] === oi ? ' checked' : '') +
      '> <span>'+opt+'</span>';
    label.querySelector('input').addEventListener('change', ()=>{
      qDiv.querySelectorAll('.option').forEach(o=>o.classList.remove('selected'));
      label.classList.add('selected');
      quizAnswers[key][qi] = oi;
    });
    qDiv.appendChild(label);
  });
  container.appendChild(qDiv);
  const btn = document.getElementById(key + '-submit-btn');
  if(btn){ btn.textContent = (qi === questions.length - 1) ? 'Ответить' : 'Далее'; }
}

function submitQuiz(key){
  const questions = key === 'quiz1' ? CONFIG.QUIZ1 : CONFIG.QUIZ2;
  const errorId = key === 'quiz1' ? 'error-quiz1' : 'error-quiz2';
  const containerId = key === 'quiz1' ? 'quiz1-questions' : 'quiz2-questions';
  const errorEl = document.getElementById(errorId);
  const qi = quizProgress[key];
  if(quizAnswers[key][qi] === undefined){
    errorEl.textContent = 'Выбери один из вариантов ответа.';
    return;
  }
  errorEl.textContent = '';
  if(qi < questions.length - 1){
    quizProgress[key] = qi + 1;
    buildQuiz(key, questions, containerId);
    return;
  }
  let correctCount = 0;
  questions.forEach((item, idx)=>{ if(quizAnswers[key][idx] === item.correct) correctCount++; });
  const score = correctCount / questions.length;
  const passed = score >= CONFIG.PASS_THRESHOLD;
  if(key === 'quiz1'){
    state.quiz1LastScore = score;
    if(passed){ state.quiz1Passed = true; saveState(state); unlockAndShow('quiz1', goToFishing); }
    else {
      saveState(state);
      document.getElementById('quiz1-score-fail').textContent =
        'Результат: ' + Math.round(score*100) + '%  (нужно ' + Math.round(CONFIG.PASS_THRESHOLD*100) + '%)';
      showScreen('screen-quiz1-fail');
    }
  } else {
    state.quiz2LastScore = score;
    if(passed){ state.quiz2Passed = true; saveState(state); unlockAndShow('quiz2', render); }
    else {
      saveState(state);
      document.getElementById('quiz2-score-fail').textContent =
        'Результат: ' + Math.round(score*100) + '%  (нужно ' + Math.round(CONFIG.PASS_THRESHOLD*100) + '%)';
      showScreen('screen-quiz2-fail');
    }
  }
}
function goToFishing(){
  window.location.href = 'game.html';
}
function retryQuiz(key){
  quizProgress[key] = 0;
  quizAnswers[key] = {};
  if(key === 'quiz1'){ buildQuiz('quiz1', CONFIG.QUIZ1, 'quiz1-questions'); showScreen('screen-quiz1'); }
  else { buildQuiz('quiz2', CONFIG.QUIZ2, 'quiz2-questions'); showScreen('screen-quiz2'); }
}

let timerInterval = null;
function startTimerLoop(){
  if(timerInterval) clearInterval(timerInterval);
  updateTimer();
  timerInterval = setInterval(()=>{
    updateTimer();
    if(isUnlocked()){ clearInterval(timerInterval); render(); }
  }, 1000);
}
function updateTimer(){
  const remaining = Math.max(0, state.unlockTimestamp - Date.now());
  const days = Math.floor(remaining / 86400000);
  const hours = Math.floor((remaining % 86400000) / 3600000);
  const mins = Math.floor((remaining % 3600000) / 60000);
  const secs = Math.floor((remaining % 60000) / 1000);
  document.getElementById('t-days').textContent = String(days).padStart(2,'0');
  document.getElementById('t-hours').textContent = String(hours).padStart(2,'0');
  document.getElementById('t-min').textContent = String(mins).padStart(2,'0');
  document.getElementById('t-sec').textContent = String(secs).padStart(2,'0');
}

function toggleAdminField(){ document.getElementById('admin-field').classList.toggle('hidden'); }
function submitAdmin(){
  const input = document.getElementById('input-admin');
  const errorEl = document.getElementById('error-admin');
  if(normalize(input.value) === normalize(CONFIG.ADMIN_CODE)){
    state.adminOverride = true;
    saveState(state);
    if(timerInterval) clearInterval(timerInterval);
    errorEl.textContent = '';
    render();
  } else { errorEl.textContent = 'Неверный код.'; }
}

let pendingAchvContinue = null;
function updateAchvCounter(){
  const earned = ACHV_ORDER.filter(id => state.achievements[id]).length;
  document.getElementById('achv-counter-text').textContent = earned + '/' + ACHV_ORDER.length;
  document.getElementById('achv-counter').classList.toggle('show', earned > 0);
}
function showAchievement(id, onContinue){
  const def = ACHIEVEMENTS[id];
  if(!def){ if(onContinue) onContinue(); return; }
  document.getElementById('achv-title').textContent = def.title;
  document.getElementById('achv-desc').textContent = def.desc;
  const photoWrap = document.getElementById('achv-photo-wrap');
  const iconEl = document.getElementById('achv-icon');
  if(def.photo){
    document.getElementById('achv-photo').src = def.photo;
    photoWrap.classList.remove('hidden');
    iconEl.classList.add('hidden');
  } else {
    photoWrap.classList.add('hidden');
    iconEl.classList.remove('hidden');
    iconEl.textContent = def.icon;
  }
  pendingAchvContinue = onContinue;
  const overlay = document.getElementById('achv-overlay');
  overlay.classList.remove('hidden');
  requestAnimationFrame(()=>{ requestAnimationFrame(()=> overlay.classList.add('active')); });
}
function continueAchievement(){
  const overlay = document.getElementById('achv-overlay');
  overlay.classList.remove('active');
  const cb = pendingAchvContinue;
  pendingAchvContinue = null;
  setTimeout(()=>{ overlay.classList.add('hidden'); if(cb) cb(); }, 380);
}
function unlockAndShow(id, onContinue){
  const alreadyEarned = !!state.achievements[id];
  state.achievements[id] = true;
  saveState(state);
  updateAchvCounter();
  if(alreadyEarned){ if(onContinue) onContinue(); return; }
  showAchievement(id, onContinue);
}

function renderAchvGallery(){
  const list = document.getElementById('achv-gallery-list');
  list.innerHTML = '';
  ACHV_ORDER.forEach(id=>{
    const def = ACHIEVEMENTS[id];
    const earned = !!state.achievements[id];
    const row = document.createElement('div');
    row.className = 'achv-row' + (earned ? '' : ' locked');
    const media = document.createElement('div');
    media.className = 'achv-row-media';
    if(earned && def.photo){
      const img = document.createElement('img');
      img.src = def.photo;
      img.alt = '';
      media.appendChild(img);
    } else if(earned){ media.textContent = def.icon; }
    else { media.textContent = '🔒'; }
    const text = document.createElement('div');
    text.className = 'achv-row-text';
    const title = document.createElement('div');
    title.className = 'achv-row-title';
    title.textContent = earned ? def.title : '???';
    const desc = document.createElement('div');
    desc.className = 'achv-row-desc';
    desc.textContent = earned ? def.desc : 'Ещё не открыто';
    text.appendChild(title);
    text.appendChild(desc);
    const check = document.createElement('div');
    check.className = 'achv-row-check';
    check.textContent = earned ? '✅' : '';
    row.appendChild(media);
    row.appendChild(text);
    row.appendChild(check);
    list.appendChild(row);
  });
  const earnedCount = ACHV_ORDER.filter(id => state.achievements[id]).length;
  document.getElementById('achv-gallery-count').textContent = earnedCount + ' из ' + ACHV_ORDER.length;
}
function openAchvGallery(){
  renderAchvGallery();
  const overlay = document.getElementById('achv-gallery-overlay');
  overlay.classList.remove('hidden');
  requestAnimationFrame(()=>{ requestAnimationFrame(()=> overlay.classList.add('active')); });
}
function closeAchvGallery(){
  const overlay = document.getElementById('achv-gallery-overlay');
  overlay.classList.remove('active');
  setTimeout(()=> overlay.classList.add('hidden'), 350);
}

updateAchvCounter();
render();

document.addEventListener('keydown', (e)=>{
  if(e.key !== 'Enter') return;
  const active = document.activeElement;
  if(active && active.tagName === 'INPUT'){
    if(active.id === 'input-code1') submitCode1();
    if(active.id === 'input-code2') submitCode2();
    if(active.id === 'input-admin') submitAdmin();
  }
});
</script>
