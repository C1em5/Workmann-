    { q: "ПЛЕЙСХОЛ", options: ["ПЛЕЙСХОЛДЕР A", "ПЛЕЙСХОЛДЕР B", "ПЛЕЙСХОЛДЕР C", "ПЛЕЙСХОЛДЕР D"], correct: 0 }
