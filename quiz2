<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg-deep:#ffe3b9;
  --bg-panel:#fffaf1;
  --bg-panel-2:#fff2dc;
  --line:#e6c393;
  --gold:#9c5f28;
  --gold-soft:#7a4a1e;
  --cream:#3a2a1a;
  --rose:#c9694f;
  --muted:#8a7256;
  --error:#b8433c;
  --success:#3f8f66;
  --font-display:'Cormorant Garamond', serif;
  --font-body:'Inter', sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;}
body{
  font-family:var(--font-body);
  background:
    radial-gradient(ellipse at 20% 10%, rgba(156,95,40,.10), transparent 45%),
    radial-gradient(ellipse at 80% 85%, rgba(201,105,79,.10), transparent 50%),
    var(--bg-deep);
  color:var(--cream);
  min-height:100vh;
  min-height:100dvh;
  overflow-x:hidden;
  position:relative;
  -webkit-tap-highlight-color:transparent;
  -webkit-font-smoothing:antialiased;
  overscroll-behavior-y:none;
}
.stars{ position:fixed; inset:0; pointer-events:none; z-index:0; }
.stars span{
  position:absolute; width:5px;height:5px; background:#fffaf1; border-radius:50%;
  opacity:.5; box-shadow:0 0 6px rgba(255,250,241,.9); animation:twinkle 7s ease-in-out infinite;
}
@keyframes twinkle{ 0%,100%{opacity:.2;} 50%{opacity:.95;} }
.stage{
  position:relative; z-index:1; min-height:100vh; min-height:100dvh;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  padding:calc(32px + env(safe-area-inset-top)) calc(18px + env(safe-area-inset-right))
          calc(32px + env(safe-area-inset-bottom)) calc(18px + env(safe-area-inset-left));
}
.screen{
  width:100%; max-width:460px; display:none; opacity:0; transform:translateY(14px);
  transition:opacity .5s ease, transform .5s ease;
}
.screen.active{ display:block; opacity:1; transform:translateY(0); }
.card{
  background:linear-gradient(180deg, var(--bg-panel), var(--bg-panel-2));
  border:1px solid var(--line); border-radius:22px; padding:38px 30px; text-align:center;
  box-shadow:0 25px 60px rgba(156,95,40,.22);
}
.eyebrow{
  font-family:var(--font-body); font-size:12px; letter-spacing:.18em; text-transform:uppercase;
  color:var(--gold); margin-bottom:10px;
}
h1{
  font-family:var(--font-display); font-weight:600; font-size:32px; line-height:1.2;
  margin-bottom:16px; color:var(--cream);
}
p{ font-size:15px; line-height:1.65; color:var(--muted); }
.lead{ color:var(--cream); font-size:16px; margin-bottom:22px; }
.constellation{ display:flex; align-items:center; justify-content:center; gap:10px; margin-bottom:28px; }
.constellation .node{
  width:9px;height:9px; border-radius:50%; background:var(--line);
  transition:background .4s ease, box-shadow .4s ease;
}
.constellation .node.done{ background:var(--gold); box-shadow:0 0 10px rgba(156,95,40,.55); }
.constellation .link{ width:22px;height:1px; background:var(--line); transition:background .4s ease; }
.constellation .link.done{ background:var(--gold); }
.field{ margin-top:22px; text-align:left; }
label{
  display:block; font-size:12px; letter-spacing:.05em; color:var(--muted);
  margin-bottom:8px; text-transform:uppercase;
}
input[type=text]{
  width:100%; padding:14px 16px; border-radius:12px; border:1px solid var(--line);
  background:rgba(156,95,40,.06); color:var(--cream); font-family:var(--font-body);
  font-size:16px; letter-spacing:.04em; outline:none; -webkit-appearance:none; appearance:none;
  touch-action:manipulation; transition:border-color .2s ease, box-shadow .2s ease;
}
input[type=text]:focus{ border-color:var(--gold); box-shadow:0 0 0 3px rgba(156,95,40,.18); }
input[type=text].shake{ animation:shake .4s ease; border-color:var(--error); }
@keyframes shake{ 0%,100%{transform:translateX(0);} 25%{transform:translateX(-6px);} 75%{transform:translateX(6px);} }
.hint-error{ margin-top:10px; font-size:13px; color:var(--error); min-height:16px; }
button{
  width:100%; padding:15px; margin-top:22px; border:none; border-radius:12px;
  font-family:var(--font-body); font-weight:600; font-size:15px; letter-spacing:.02em; cursor:pointer;
  -webkit-appearance:none; appearance:none; touch-action:manipulation;
  background:linear-gradient(135deg, var(--gold), #b98a4a); color:#ffffff;
  transition:transform .2s ease, box-shadow .2s ease, opacity .2s ease;
}
button:active{ transform:scale(.98); }
@media (hover:hover) and (pointer:fine){
  button:hover{ transform:translateY(-1px); box-shadow:0 10px 24px rgba(156,95,40,.22); }
}
button:disabled{ opacity:.4; cursor:not-allowed; transform:none; box-shadow:none; }
button.ghost{ background:transparent; border:1px solid var(--line); color:var(--muted); font-weight:500; }
@media (hover:hover) and (pointer:fine){
  button.ghost:hover{ border-color:var(--gold); color:var(--gold-soft); box-shadow:none; }
}
button.text-link{
  width:auto; background:none; padding:6px 0; margin-top:14px; font-size:12px;
  letter-spacing:.05em; text-transform:uppercase; color:var(--muted);
  text-decoration:underline; text-underline-offset:3px;
}
@media (hover:hover) and (pointer:fine){
  button.text-link:hover{ color:var(--gold-soft); transform:none; box-shadow:none; }
}
.question{ text-align:left; margin-top:22px; padding-top:18px; border-top:1px solid var(--line); }
.question:first-of-type{ border-top:none; padding-top:0; }
.question .q-text{ font-family:var(--font-display); font-size:19px; color:var(--cream); margin-bottom:12px; }
.option{
  display:flex; align-items:center; gap:10px; padding:13px 14px; border-radius:10px;
  border:1px solid var(--line); margin-bottom:8px; cursor:pointer; touch-action:manipulation;
  transition:border-color .2s ease, background .2s ease;
}
@media (hover:hover) and (pointer:fine){ .option:hover{ border-color:var(--gold); } }
.option input{ accent-color:var(--gold); width:19px; height:19px; flex-shrink:0; }
.option.selected{ border-color:var(--gold); background:rgba(156,95,40,.10); }
.option span{ font-size:14px; color:var(--cream); }
.timer{ display:flex; justify-content:center; gap:14px; margin:26px 0 6px; }
.timer .unit{ min-width:64px; }
.timer .num{
  font-family:var(--font-display); font-size:34px; color:var(--gold-soft); font-variant-numeric:tabular-nums;
}
.timer .label{
  font-size:10px; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); margin-top:2px;
}
.admin-toggle{ margin-top:26px; padding-top:18px; border-top:1px solid var(--line); }
.score-badge{
  display:inline-block; margin:6px 0 18px; padding:6px 16px; border-radius:999px;
  border:1px solid var(--gold); color:var(--gold-soft); font-size:13px; letter-spacing:.04em;
}
.hidden{display:none !important;}
.footnote{ margin-top:18px; font-size:11px; color:var(--line); }

.achv-counter{
  position:fixed; top:calc(14px + env(safe-area-inset-top)); right:14px; z-index:5;
  display:flex; align-items:center; gap:6px; padding:7px 13px; border-radius:999px;
  background:rgba(255,250,241,.75); border:1px solid var(--line); backdrop-filter:blur(6px);
  font-size:12px; letter-spacing:.03em; color:var(--gold-soft); font-weight:600;
  box-shadow:0 6px 18px rgba(156,95,40,.14); opacity:0; transform:translateY(-6px);
  transition:opacity .4s ease, transform .4s ease; cursor:pointer; touch-action:manipulation;
}
.achv-counter.show{ opacity:1; transform:translateY(0); }
@media (hover:hover) and (pointer:fine){ .achv-counter:hover{ border-color:var(--gold); } }
.achv-overlay{
  position:fixed; inset:0; z-index:50; display:flex; align-items:center; justify-content:center;
  padding:20px calc(20px + env(safe-area-inset-right)) calc(20px + env(safe-area-inset-bottom)) calc(20px + env(safe-area-inset-left));
  background:rgba(20,12,4,.6); backdrop-filter:blur(4px); opacity:0; pointer-events:none;
  transition:opacity .4s ease;
}
.achv-overlay.active{ opacity:1; pointer-events:auto; }
.achv-card{
  width:100%; max-width:360px; background:linear-gradient(180deg, var(--bg-panel), var(--bg-panel-2));
  border:1px solid var(--line); border-radius:24px; padding:24px 22px 28px; text-align:center;
  box-shadow:0 35px 80px rgba(0,0,0,.4); transform:scale(.35) translateY(70px) rotate(-8deg); opacity:0;
  transition:transform .65s cubic-bezier(.34,1.56,.64,1), opacity .5s ease; max-height:88vh; overflow-y:auto;
}
.achv-overlay.active .achv-card{ transform:scale(1) translateY(0) rotate(0deg); opacity:1; }
.achv-photo-wrap{
  width:100%; border-radius:16px; overflow:hidden; border:1px solid var(--line); margin-bottom:16px;
  box-shadow:0 14px 34px rgba(156,95,40,.28); transform:scale(1.08);
  animation:achvPhotoIn .7s cubic-bezier(.34,1.56,.64,1) .15s both;
}
@keyframes achvPhotoIn{ 0%{transform:scale(1.3); filter:brightness(1.4);} 100%{transform:scale(1); filter:brightness(1);} }
.achv-photo-wrap img{ width:100%; display:block; }
.achv-icon{ font-size:46px; margin-bottom:10px; animation:achvPop .7s cubic-bezier(.34,1.56,.64,1) .15s both; }
@keyframes achvPop{
  0%{transform:scale(0) rotate(-25deg); opacity:0;}
  60%{transform:scale(1.25) rotate(10deg); opacity:1;}
  100%{transform:scale(1) rotate(0); opacity:1;}
}
.achv-eyebrow{ font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:var(--gold); margin-bottom:8px; }
.achv-title{ font-family:var(--font-display); font-weight:600; font-size:24px; color:var(--cream); margin-bottom:10px; }
.achv-desc{ font-size:14px; line-height:1.6; color:var(--muted); margin-bottom:4px; }
.achv-card button{ margin-top:20px; }
.achv-gallery-card{
  width:100%; max-width:400px; background:linear-gradient(180deg, var(--bg-panel), var(--bg-panel-2));
  border:1px solid var(--line); border-radius:24px; padding:26px 22px 22px; text-align:left;
  box-shadow:0 35px 80px rgba(0,0,0,.4); transform:scale(.9) translateY(20px); opacity:0;
  transition:transform .4s cubic-bezier(.34,1.56,.64,1), opacity .35s ease; max-height:85vh; overflow-y:auto;
}
.achv-overlay.active .achv-gallery-card{ transform:scale(1) translateY(0); opacity:1; }
.achv-gallery-head{ text-align:center; margin-bottom:18px; }
.achv-gallery-head .achv-eyebrow{ margin-bottom:6px; }
.achv-gallery-head h2{ font-family:var(--font-display); font-weight:600; font-size:24px; color:var(--cream); }
.achv-gallery-list{ display:flex; flex-direction:column; gap:10px; }
.achv-row{
  display:flex; align-items:center; gap:13px; padding:12px 13px; border-radius:14px;
  border:1px solid var(--line); background:rgba(156,95,40,.05);
}
.achv-row.locked{ opacity:.5; }
.achv-row-media{
  width:46px; height:46px; border-radius:12px; flex-shrink:0; display:flex; align-items:center;
  justify-content:center; font-size:22px; background:rgba(156,95,40,.10); border:1px solid var(--line);
  overflow:hidden;
}
.achv-row-media img{ width:100%; height:100%; object-fit:cover; }
.achv-row-text{ flex:1; min-width:0; }
.achv-row-title{ font-size:14px; font-weight:600; color:var(--cream); margin-bottom:2px; }
.achv-row-desc{ font-size:12px; line-height:1.4; color:var(--muted); }
.achv-row-check{ font-size:16px; flex-shrink:0; }
.achv-gallery-card button{ margin-top:20px; }

@media (max-width:400px){
  .card{ padding:30px 20px; }
  .stage{
    padding-left:calc(12px + env(safe-area-inset-left));
    padding-right:calc(12px + env(safe-area-inset-right));
  }
  h1{ font-size:27px; }
  .timer{ gap:8px; }
  .timer .unit{ min-width:52px; }
  .timer .num{ font-size:27px; }
}
@supports (padding: max(0px)){
  .stage{ padding-bottom:max(32px, calc(24px + env(safe-area-inset-bottom))); }
}
</style>
</head>
<body>

<div class="stars" id="stars"></div>

<div class="achv-counter" id="achv-counter" onclick="openAchvGallery()">🏆 <span id="achv-counter-text">0/4</span></div>

<div class="achv-overlay" id="achv-overlay">
  <div class="achv-card">
    <div class="achv-eyebrow">Ачивка получена</div>
    <div class="achv-photo-wrap hidden" id="achv-photo-wrap">
      <img id="achv-photo" src="" alt="">
    </div>
    <div class="achv-icon hidden" id="achv-icon"></div>
    <div class="achv-title" id="achv-title"></div>
    <div class="achv-desc" id="achv-desc"></div>
    <button onclick="continueAchievement()">Продолжить</button>
  </div>
</div>

<div class="achv-overlay" id="achv-gallery-overlay">
  <div class="achv-gallery-card">
    <div class="achv-gallery-head">
      <div class="achv-eyebrow">Твои ачивки</div>
      <h2 id="achv-gallery-count">0 из 4</h2>
    </div>
    <div class="achv-gallery-list" id="achv-gallery-list"></div>
    <button class="ghost" onclick="closeAchvGallery()">Закрыть</button>
  </div>
</div>

<div class="stage">

  <div class="constellation" id="constellation"></div>

  <div class="screen" id="screen-code1">
    <div class="card">
      <div class="eyebrow">Глава I</div>
      <h1>Здесь начинается твой квест</h1>
      <p>Введи код чтобы начать</p>
      <div class="field">
        <label for="input-code1">КОД С ПИСЬМА</label>
        <input type="text" id="input-code1" autocomplete="off" placeholder="••••••">
      </div>
      <div class="hint-error" id="error-code1"></div>
      <button onclick="submitCode1()">Открыть</button>
    </div>
  </div>

  <div class="screen" id="screen-quiz1">
    <div class="card">
      <div class="eyebrow">Глава II</div>
      <h1>Первое испытание</h1>
      <a href="game.html">Мини-игра</a>
      <p class="lead">Отвечай честно — вселенная считает.</p>
      <div id="quiz1-questions"></div>
      <div class="hint-error" id="error-quiz1"></div>
      <button id="quiz1-submit-btn" onclick="submitQuiz('quiz1')">Ответить</button>
    </div>
  </div>

  <div class="screen" id="screen-quiz1-fail">
    <div class="card">
      <div class="eyebrow">Глава II · Итог</div>
      <h1>Почти получилось</h1>
      <div class="score-badge" id="quiz1-score-fail"></div>
      <p>Судьба любит настойчивых. Попробуй ещё раз.</p>
      <button onclick="retryQuiz('quiz1')">Попробовать снова</button>
    </div>
  </div>

  <div class="screen" id="screen-quiz1-success">
    <div class="card">
      <div class="eyebrow">Глава III</div>
      <h1>Ты справилась ✨</h1>
      <div class="score-badge" id="quiz1-score-success"></div>
      <p id="gift1-text">Первый подарок уже твой. Загляни в <a href="...">Cюда</a>.</p>
      <button onclick="continueToLock()">Продолжить</button>
    </div>
  </div>

  <div class="screen" id="screen-lock">
    <div class="card">
      <div class="eyebrow">Глава IV</div>
      <h1>Второй подарок ждёт своего часа</h1>
      <p>Время — тоже часть подарка. Возвращайся, когда звёзды сойдутся:</p>
      <div class="timer" id="timer">
        <div class="unit"><div class="num" id="t-days">00</div><div class="label">дней</div></div>
        <div class="unit"><div class="num" id="t-hours">00</div><div class="label">часов</div></div>
        <div class="unit"><div class="num" id="t-min">00</div><div class="label">минут</div></div>
        <div class="unit"><div class="num" id="t-sec">00</div><div class="label">секунд</div></div>
      </div>
      <div class="admin-toggle">
        <button class="text-link" onclick="toggleAdminField()">У меня есть особый код</button>
        <div id="admin-field" class="hidden">
          <div class="field">
            <input type="text" id="input-admin" autocomplete="off" placeholder="Особый код">
          </div>
          <div class="hint-error" id="error-admin"></div>
          <button class="ghost" onclick="submitAdmin()">Снять блокировку</button>
        </div>
      </div>
    </div>
</div>

  <div class="screen" id="screen-code2-entry">
    <div class="card">
      <div class="eyebrow">Глава V</div>
      <h1>Время пришло</h1>
      <p>Хочешь узнать, что дальше? Введи второй код</p>
      <div class="field">
        <label for="input-code2">КОД</label>
        <input type="text" id="input-code2" autocomplete="off" placeholder="••••••">
      </div>
      <div class="hint-error" id="error-code2"></div>
      <button onclick="submitCode2()">Продолжить</button>
    </div>
  </div>

<div class="screen" id="screen-quiz2">
    <div class="card">
      <div class="eyebrow">Глава V</div>
      <h1>Финальное испытание</h1>
      <p class="lead">Последний шаг перед финалом.</p>
      <div id="quiz2-questions"></div>
      <div class="hint-error" id="error-quiz2"></div>
      <button id="quiz2-submit-btn" onclick="submitQuiz('quiz2')">Ответить</button>
    </div>
  </div>

  <div class="screen" id="screen-quiz2-fail">
    <div class="card">
      <div class="eyebrow">Глава V · Итог</div>
      <h1>Ещё чуть-чуть</h1>
      <div class="score-badge" id="quiz2-score-fail"></div>
      <p>Финал уже так близко. Попробуй снова.</p>
      <button onclick="retryQuiz('quiz2')">Попробовать снова</button>
    </div>
  </div>

  <div class="screen" id="screen-final">
    <div class="card">
      <div class="eyebrow">Финал</div>
      <h1>С юбилеем, любовь моя 🤍</h1>
      <div class="score-badge" id="quiz2-score-final"></div>
      <p id="gift2-text">[СЮДА ОПИСАНИЕ ВТОРОГО ПОДАРКА — что она получает и где его найти]</p>
      <p class="footnote">Квест пройден полностью.</p>
    </div>
  </div>

</div>

<script>
const CONFIG = {
